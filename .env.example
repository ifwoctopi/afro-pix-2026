# Example environment variables for the React front-end
# Copy this file to `.env` and fill in your own keys before running.

# API gateway (for fetch calls, leave blank to use relative)
REACT_APP_API_URL=

# Supabase (authentication and database)
REACT_APP_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
REACT_APP_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Google Maps client-side key used by @react-google-maps/api
REACT_APP_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Gemini (backend AI model for /api/simplify in api.py)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Optional: model override
# GEMINI_MODEL=gemini-1.5-flash
